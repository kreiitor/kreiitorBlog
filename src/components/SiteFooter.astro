---
import { siteConfig } from '../data/site';
import { withBase } from '../utils/url';
---

<footer class="border-t border-[color:var(--color-line)] py-12">
	<div class="page-shell grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
		<div class="surface-card float-panel rounded-[2.5rem] p-6 sm:p-8">
			<p class="font-display text-sm font-bold uppercase tracking-[0.2em] text-[color:var(--color-accent-strong)]">
				Stay in Motion
			</p>
			<p class="mt-3 font-display text-3xl font-bold text-[color:var(--color-ink)]">{siteConfig.title}</p>
			<p class="mt-4 max-w-2xl text-sm leading-7 text-[color:var(--color-ink-soft)]">
				{siteConfig.description}
			</p>
		</div>

		<div class="flex flex-col items-start gap-4 text-sm text-[color:var(--color-ink-soft)] lg:items-end">
			<div class="flex flex-wrap gap-3">
				<a href={withBase('/archive/')} class="rounded-full bg-white/70 px-4 py-2 hover:text-[color:var(--color-ink)]">
					归档
				</a>
				<a href={withBase('/search/')} class="rounded-full bg-white/70 px-4 py-2 hover:text-[color:var(--color-ink)]">
					搜索
				</a>
				<a href={withBase('/rss.xml')} class="rounded-full bg-white/70 px-4 py-2 hover:text-[color:var(--color-ink)]">
					RSS
				</a>
			</div>
			<div class="flex flex-wrap gap-3">
				{siteConfig.socialLinks.map((link) => (
					<a href={link.href} target="_blank" rel="noreferrer" class="hover:text-[color:var(--color-ink)]">
						{link.label}
					</a>
				))}
			</div>
			<p>&copy; {new Date().getFullYear()} {siteConfig.author}. Built with Astro.</p>
		</div>
	</div>
</footer>
