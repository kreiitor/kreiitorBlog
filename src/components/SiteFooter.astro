---
import { siteConfig } from '../data/site';
import { withBase } from '../utils/url';
---

<footer class="border-t border-[color:var(--color-line)] py-10">
	<div class="page-shell flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
		<div class="space-y-3">
			<p class="font-display text-2xl font-bold text-[color:var(--color-ink)]">{siteConfig.title}</p>
			<p class="max-w-2xl text-sm leading-7 text-[color:var(--color-ink-soft)]">
				{siteConfig.description}
			</p>
		</div>

		<div class="flex flex-col items-start gap-3 text-sm text-[color:var(--color-ink-soft)] md:items-end">
			<div class="flex flex-wrap gap-3">
				<a href={withBase('/archive/')} class="hover:text-[color:var(--color-ink)]">归档</a>
				<a href={withBase('/search/')} class="hover:text-[color:var(--color-ink)]">搜索</a>
				<a href={withBase('/rss.xml')} class="hover:text-[color:var(--color-ink)]">RSS</a>
			</div>
			<div class="flex flex-wrap gap-3">
				{siteConfig.socialLinks.map((link) => (
					<a href={link.href} target="_blank" rel="noreferrer" class="hover:text-[color:var(--color-ink)]">
						{link.label}
					</a>
				))}
			</div>
			<p>&copy; {new Date().getFullYear()} {siteConfig.author}. Built with Astro.</p>
		</div>
	</div>
</footer>
