---
import type { PostEntry } from '../utils/content';
import { getReadingTime } from '../utils/content';
import { formatDate } from '../utils/date';
import { withBase } from '../utils/url';
import TagLink from './TagLink.astro';

interface Props {
	post: PostEntry;
	featured?: boolean;
}

const { post, featured = false } = Astro.props;
---

<article class:list={['surface-card group flex h-full flex-col overflow-hidden rounded-[2rem] hover:-rotate-[0.35deg]', featured && 'md:col-span-2 xl:col-span-1']}>
	{post.data.cover && (
		<a href={withBase(`/blog/${post.id}/`)} class="block overflow-hidden">
			<img
				src={withBase(post.data.cover)}
				alt={post.data.title}
				class="h-56 w-full object-cover transition duration-500 group-hover:scale-[1.03]"
				loading="lazy"
			/>
		</a>
	)}
	<div class="relative flex h-full flex-col gap-5 p-6">
		<div class="pointer-events-none absolute right-4 top-4 h-20 w-20 rounded-full bg-[rgba(242,133,94,0.08)] blur-2xl"></div>
		<div class="flex flex-wrap items-center gap-3 text-sm text-[color:var(--color-ink-soft)]">
			<time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
			<span>·</span>
			<span>{getReadingTime(post)} 分钟阅读</span>
		</div>
		<div class="space-y-3">
			<h3 class="font-display text-2xl font-bold tracking-tight text-[color:var(--color-ink)]">
				<a href={withBase(`/blog/${post.id}/`)} class="transition group-hover:text-[color:var(--color-accent-strong)]">
					{post.data.title}
				</a>
			</h3>
			<p class="text-sm leading-7 text-[color:var(--color-ink-soft)]">{post.data.description}</p>
		</div>
		<div class="mt-auto flex items-center justify-between gap-4">
			<div class="flex flex-wrap gap-2">
				{post.data.tags.map((tag) => (
					<TagLink tag={tag} />
				))}
			</div>
			<a
				href={withBase(`/blog/${post.id}/`)}
				class="shrink-0 rounded-full bg-[rgba(20,33,61,0.06)] px-3 py-1.5 text-xs font-semibold text-[color:var(--color-ink)] transition group-hover:bg-[rgba(242,133,94,0.14)] group-hover:text-[color:var(--color-accent-strong)]"
			>
				继续阅读
			</a>
		</div>
	</div>
</article>
