---
import type { ProjectEntry } from '../utils/content';
import { formatDate } from '../utils/date';
import { withBase } from '../utils/url';
import TagLink from './TagLink.astro';

interface Props {
	project: ProjectEntry;
}

const { project } = Astro.props;
---

<article class="surface-card group flex h-full flex-col overflow-hidden rounded-[2rem] hover:rotate-[0.25deg]">
	{project.data.cover && (
		<a href={withBase(`/projects/${project.id}/`)} class="block overflow-hidden">
			<img
				src={withBase(project.data.cover)}
				alt={project.data.title}
				class="h-56 w-full object-cover transition duration-500 group-hover:scale-[1.03]"
				loading="lazy"
			/>
		</a>
	)}
	<div class="relative flex h-full flex-col gap-5 p-6">
		<div class="pointer-events-none absolute bottom-4 right-4 h-20 w-20 rounded-full bg-[rgba(45,106,142,0.10)] blur-2xl"></div>
		<div class="flex flex-wrap items-center gap-3 text-sm text-[color:var(--color-ink-soft)]">
			<span class="rounded-full bg-[rgba(242,133,94,0.12)] px-3 py-1 font-semibold text-[color:var(--color-accent-strong)]">
				{project.data.status}
			</span>
			<time datetime={project.data.pubDate.toISOString()}>{formatDate(project.data.pubDate)}</time>
		</div>
		<div class="space-y-3">
			<h3 class="font-display text-2xl font-bold tracking-tight text-[color:var(--color-ink)]">
				<a href={withBase(`/projects/${project.id}/`)} class="transition group-hover:text-[color:var(--color-accent-strong)]">
					{project.data.title}
				</a>
			</h3>
			<p class="text-sm leading-7 text-[color:var(--color-ink-soft)]">{project.data.summary}</p>
		</div>
		<div class="mt-auto flex items-center justify-between gap-4">
			<div class="flex flex-wrap gap-2">
				{project.data.tags.map((tag) => (
					<TagLink tag={tag} />
				))}
			</div>
			<a
				href={withBase(`/projects/${project.id}/`)}
				class="shrink-0 rounded-full bg-[rgba(45,106,142,0.10)] px-3 py-1.5 text-xs font-semibold text-[color:var(--color-ocean)] transition group-hover:bg-[rgba(45,106,142,0.18)]"
			>
				查看详情
			</a>
		</div>
	</div>
</article>
