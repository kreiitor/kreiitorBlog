---
import { navLinks, siteConfig } from '../data/site';
import { withBase } from '../utils/url';

interface Props {
	currentPath: string;
}

const { currentPath } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-[color:var(--color-line)] bg-[rgba(247,244,238,0.82)] backdrop-blur-xl">
	<div class="page-shell grid gap-4 py-4 lg:grid-cols-[auto_minmax(0,1fr)_auto] lg:items-center">
		<a href={withBase('/')} class="group flex items-center gap-3 text-sm text-[color:var(--color-ink-soft)] transition hover:text-[color:var(--color-ink)]">
			<div class="flex h-11 w-11 items-center justify-center rounded-[1.35rem] bg-[color:var(--color-ink)] font-display text-base font-bold tracking-[0.18em] text-white shadow-lg shadow-[rgba(20,33,61,0.18)] transition group-hover:-translate-y-0.5">
				AI
			</div>
			<div>
				<p class="font-display text-base font-bold text-[color:var(--color-ink)]">{siteConfig.title}</p>
				<p>{siteConfig.tagline}</p>
			</div>
		</a>

		<nav class="flex flex-wrap items-center gap-2 text-sm font-medium text-[color:var(--color-ink-soft)] lg:justify-center">
			{navLinks.map((item) => {
				const active =
					item.href === '/'
						? currentPath === '/'
						: currentPath.startsWith(item.href.replace(/\/$/, ''));

				return (
					<a
						href={withBase(item.href)}
						class:list={[
							'rounded-full px-4 py-2 transition',
							active
								? 'bg-[color:var(--color-ink)] text-white shadow-lg'
								: 'hover:bg-white/80 hover:text-[color:var(--color-ink)]',
						]}
					>
						{item.label}
					</a>
				);
			})}
		</nav>

		<div class="flex items-center lg:justify-end">
			<a
				href={withBase('/search/')}
				class="inline-flex items-center gap-2 rounded-full border border-[color:var(--color-line)] bg-white/85 px-4 py-2 text-[color:var(--color-ink)] shadow-sm transition hover:-translate-y-0.5 hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent-strong)]"
				aria-label="打开站内搜索"
				title="搜索"
			>
				<svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current stroke-2">
					<circle cx="11" cy="11" r="7"></circle>
					<path d="m20 20-3.5-3.5"></path>
				</svg>
				<span class="font-semibold">搜索</span>
			</a>
		</div>
	</div>
</header>
