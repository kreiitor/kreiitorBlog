---
import { navLinks, siteConfig } from '../data/site';
import { withBase } from '../utils/url';

interface Props {
	currentPath: string;
}

const { currentPath } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-[color:var(--color-line)] bg-[rgba(247,244,238,0.75)] backdrop-blur-xl">
	<div class="page-shell flex flex-col gap-4 py-4 lg:flex-row lg:items-center lg:justify-between">
		<a href={withBase('/')} class="flex items-center gap-3 text-sm text-[color:var(--color-ink-soft)] transition hover:text-[color:var(--color-ink)]">
			<div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-[color:var(--color-ink)] font-display text-base font-bold tracking-[0.18em] text-white">
				AI
			</div>
			<div>
				<p class="font-display text-base font-bold text-[color:var(--color-ink)]">{siteConfig.title}</p>
				<p>{siteConfig.tagline}</p>
			</div>
		</a>

		<div class="flex flex-col gap-3 lg:items-end">
			<a
				href={withBase('/search/')}
				class="inline-flex items-center gap-2 self-start rounded-full border border-[color:var(--color-line)] bg-white/80 px-4 py-2 text-[color:var(--color-ink)] transition hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent-strong)] lg:self-auto"
				aria-label="打开站内搜索"
				title="搜索"
			>
				<span class="text-base">⌕</span>
				<span class="font-semibold">搜索</span>
			</a>
			<nav class="flex flex-wrap items-center gap-2 text-sm font-medium text-[color:var(--color-ink-soft)]">
				{navLinks.map((item) => {
					const active =
						item.href === '/'
							? currentPath === '/'
							: currentPath.startsWith(item.href.replace(/\/$/, ''));

					return (
						<a
							href={withBase(item.href)}
							class:list={[
								'rounded-full px-4 py-2 transition',
								active
									? 'bg-[color:var(--color-ink)] text-white shadow-lg'
									: 'hover:bg-white/80 hover:text-[color:var(--color-ink)]',
							]}
						>
							{item.label}
						</a>
					);
				})}
			</nav>
		</div>
	</div>
</header>
