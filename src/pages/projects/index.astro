---
import { getCollection } from 'astro:content';
import ProjectCard from '../../components/ProjectCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProjects } from '../../utils/content';

const projects = getProjects(await getCollection('projects'));
---

<BaseLayout title="项目" description="展示论文、实验与工具型项目条目。">
	<div data-pagefind-ignore>
		<section class="page-shell pt-12">
			<div class="surface-card float-panel rounded-[2.75rem] p-8 sm:p-10">
				<SectionHeading
					kicker="Projects"
					title="项目页"
					description="这里独立承载论文摘要、实验进展与工具型项目，让博客写作和项目展示共享同一套站点框架。"
				/>
			</div>
		</section>

		<section class="page-shell mt-8">
			<div class="section-grid">
				{projects.map((project) => (
					<ProjectCard project={project} />
				))}
			</div>
		</section>
	</div>
</BaseLayout>
