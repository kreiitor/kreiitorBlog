---
import SearchPanel from '../components/SearchPanel.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="搜索" description="使用 Pagefind 进行站内静态搜索。">
	<section data-pagefind-ignore class="page-shell pt-12">
		<div class="grid gap-8 lg:grid-cols-[minmax(0,1.1fr)_320px]">
			<SearchPanel
				title="正式搜索页"
				description="这里会搜索博客文章、项目页面和站内正文内容，并把查询保留在地址栏里，方便分享搜索结果。"
			/>

			<aside class="space-y-6">
				<div class="surface-card float-panel rounded-[2.25rem] p-6">
					<p class="font-display text-sm font-bold uppercase tracking-[0.2em] text-[color:var(--color-accent-strong)]">
						Search Tips
					</p>
					<ul class="mt-4 space-y-3 text-sm leading-7 text-[color:var(--color-ink-soft)]">
						<li>优先尝试主题词，例如“算法学习”“实验复现”。</li>
						<li>如果结果太少，可以减少限定词。</li>
						<li>如果结果太多，可以换更具体的技术名词。</li>
					</ul>
				</div>
				<div class="surface-card float-panel rounded-[2.25rem] p-6">
					<p class="font-display text-sm font-bold uppercase tracking-[0.2em] text-[color:var(--color-ocean)]">
						Indexed Content
					</p>
					<p class="mt-3 text-sm leading-7 text-[color:var(--color-ink-soft)]">
						当前索引范围已收紧为文章详情页和项目详情页，避免导航页、归档页和标签页干扰结果质量。
					</p>
				</div>
			</aside>
		</div>
	</section>
</BaseLayout>
