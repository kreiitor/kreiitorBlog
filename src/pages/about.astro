---
import BaseLayout from '../layouts/BaseLayout.astro';
import { aboutSections, siteConfig } from '../data/site';
import { withBase } from '../utils/url';
---

<BaseLayout title="关于" description="个人简介、研究兴趣与站点维护说明。">
	<section class="page-shell pt-12">
		<div class="grid gap-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(300px,0.65fr)]">
			<div class="surface-card rounded-[2.5rem] p-8 sm:p-10">
				<p class="font-display text-sm font-bold uppercase tracking-[0.2em] text-[color:var(--color-accent-strong)]">
					About
				</p>
				<h1 class="mt-4 font-display text-4xl font-bold tracking-tight text-[color:var(--color-ink)] sm:text-5xl">
					{siteConfig.author}
				</h1>
				<p class="mt-4 text-lg leading-8 text-[color:var(--color-ink-soft)]">
					{siteConfig.role}，目前以中文写作为主，持续整理研究问题、论文思路和工程实验过程。
				</p>
				<div class="mt-8 flex flex-wrap gap-3">
					{siteConfig.socialLinks.map((link) => (
						<a
							href={link.href}
							target="_blank"
							rel="noreferrer"
							class="rounded-full border border-[color:var(--color-line)] px-4 py-2 text-sm font-semibold text-[color:var(--color-ink)] hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent-strong)]"
						>
							{link.label}
						</a>
					))}
				</div>
			</div>

			<div class="surface-card flex flex-col items-start rounded-[2.5rem] p-8">
				<img src={withBase(siteConfig.avatar)} alt={siteConfig.author} class="h-24 w-24 rounded-[1.75rem] object-cover" />
				<p class="mt-6 font-display text-2xl font-bold text-[color:var(--color-ink)]">{siteConfig.location}</p>
				<p class="mt-3 text-sm leading-7 text-[color:var(--color-ink-soft)]">
					品牌信息、头像、论文题目与社交链接都集中在
					<code class="rounded bg-[rgba(20,33,61,0.06)] px-1.5 py-1 text-xs">src/data/site.ts</code>
					里，后续替换真实信息时不需要改动页面结构。
				</p>
			</div>
		</div>
	</section>

	<section class="page-shell mt-8 grid gap-6 md:grid-cols-3">
		{aboutSections.map((section) => (
			<div class="surface-card rounded-[2rem] p-6">
				<h2 class="font-display text-2xl font-bold text-[color:var(--color-ink)]">{section.title}</h2>
				<ul class="mt-5 space-y-3 text-sm leading-7 text-[color:var(--color-ink-soft)]">
					{section.items.map((item) => (
						<li>{item}</li>
					))}
				</ul>
			</div>
		))}
	</section>
</BaseLayout>
