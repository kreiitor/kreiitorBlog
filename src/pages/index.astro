---
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TagLink from '../components/TagLink.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site';
import {
	getFeaturedPosts,
	getFeaturedProjects,
	getLatestUpdates,
	getPublishedPosts,
	getProjects,
	getTagSummaries,
} from '../utils/content';
import { formatDate } from '../utils/date';
import { withBase } from '../utils/url';

const posts = await getCollection('posts');
const projects = await getCollection('projects');
const publishedPosts = getPublishedPosts(posts);
const sortedProjects = getProjects(projects);
const featuredPosts = getFeaturedPosts(posts, 3);
const featuredProjects = getFeaturedProjects(projects, 2);
const latestUpdates = getLatestUpdates(posts, projects, 5);
const tags = getTagSummaries(posts, projects).slice(0, 8);
---

<BaseLayout>
	<div data-pagefind-ignore>
		<section class="page-shell pt-10 sm:pt-16">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1.2fr)_minmax(300px,0.8fr)] lg:items-start">
				<div class="surface-card float-panel rounded-[2.75rem] p-8 sm:p-10">
					<div class="relative space-y-8">
						<div class="space-y-4">
							<p class="font-display text-sm font-bold uppercase tracking-[0.24em] text-[color:var(--color-accent-strong)]">
								{siteConfig.hero.kicker}
							</p>
							<h1 class="max-w-4xl font-display text-4xl font-bold tracking-tight text-[color:var(--color-ink)] sm:text-5xl lg:text-6xl">
								{siteConfig.hero.title}
							</h1>
							<p class="max-w-3xl text-base leading-8 text-[color:var(--color-ink-soft)] sm:text-lg">
								{siteConfig.hero.description}
							</p>
						</div>

						<div class="flex flex-wrap gap-3">
							<a
								href={withBase('/blog/')}
								class="inline-flex items-center justify-center rounded-full bg-[color:var(--color-ink)] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[color:var(--color-accent-strong)]"
							>
								进入博客
							</a>
							<a
								href={withBase('/projects/')}
								class="inline-flex items-center justify-center rounded-full border border-[color:var(--color-line)] px-6 py-3 text-sm font-semibold text-[color:var(--color-ink)] transition hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent-strong)]"
							>
								查看项目
							</a>
							<a
								href={withBase('/about/')}
								class="inline-flex items-center justify-center rounded-full border border-transparent px-6 py-3 text-sm font-semibold text-[color:var(--color-ocean)] transition hover:bg-white/70"
							>
								认识我
							</a>
						</div>

						<div class="grid gap-4 sm:grid-cols-3">
							<div class="rounded-[1.75rem] bg-white/80 p-5">
								<p class="text-sm text-[color:var(--color-ink-soft)]">博客文章</p>
								<p class="mt-2 font-display text-4xl font-bold text-[color:var(--color-ink)]">{publishedPosts.length}</p>
							</div>
							<div class="rounded-[1.75rem] bg-white/80 p-5">
								<p class="text-sm text-[color:var(--color-ink-soft)]">项目条目</p>
								<p class="mt-2 font-display text-4xl font-bold text-[color:var(--color-ink)]">{sortedProjects.length}</p>
							</div>
							<div class="rounded-[1.75rem] bg-white/80 p-5">
								<p class="text-sm text-[color:var(--color-ink-soft)]">关注主题</p>
								<p class="mt-2 font-display text-xl font-bold text-[color:var(--color-ink)]">研究 + 写作</p>
							</div>
						</div>
					</div>
				</div>

				<div class="space-y-6">
					<div class="surface-card float-panel rounded-[2.5rem] p-7">
						<p class="font-display text-sm font-bold uppercase tracking-[0.2em] text-[color:var(--color-accent-strong)]">
							研究焦点
						</p>
						<div class="mt-5 flex flex-wrap gap-3">
							{siteConfig.hero.highlights.map((highlight) => (
								<span class="rounded-full bg-[rgba(20,33,61,0.06)] px-4 py-2 text-sm font-semibold text-[color:var(--color-ink)]">
									{highlight}
								</span>
							))}
						</div>
					</div>

					<div class="surface-card float-panel rounded-[2.5rem] p-7">
						<p class="font-display text-sm font-bold uppercase tracking-[0.2em] text-[color:var(--color-accent-strong)]">
							最新动态入口
						</p>
						<ul class="mt-5 space-y-4">
							{latestUpdates.slice(0, 3).map((item) => (
								<li class="rounded-[1.5rem] bg-white/80 p-4">
									<p class="text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--color-ocean)]">
										{item.type === 'post' ? 'Blog Update' : 'Project Update'}
									</p>
									<a href={withBase(item.href)} class="mt-2 block font-display text-xl font-bold text-[color:var(--color-ink)] hover:text-[color:var(--color-accent-strong)]">
										{item.title}
									</a>
									<p class="mt-2 text-sm leading-7 text-[color:var(--color-ink-soft)]">{item.summary}</p>
								</li>
							))}
						</ul>
					</div>
				</div>
			</div>
		</section>

		<section class="page-shell mt-16 space-y-8">
			<SectionHeading
				kicker="Featured Posts"
				title="代表文章"
				description="先用示例内容覆盖完整的数据流，后续可以逐篇替换为论文阅读笔记、实验日志与方法拆解。"
				linkHref={withBase('/blog/')}
				linkLabel="查看全部文章"
			/>
			<div class="section-grid">
				{featuredPosts.map((post) => (
					<PostCard post={post} />
				))}
			</div>
		</section>

		<section class="page-shell mt-16 space-y-8">
			<SectionHeading
				kicker="Selected Work"
				title="项目精选"
				description="使用独立的 projects 集合承载论文、实验与工具型项目，让博客写作和项目展示共享同一套站点结构。"
				linkHref={withBase('/projects/')}
				linkLabel="浏览项目"
			/>
			<div class="section-grid">
				{featuredProjects.map((project) => (
					<ProjectCard project={project} />
				))}
			</div>
		</section>

		<section class="page-shell mt-16 grid gap-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
			<div class="surface-card float-panel rounded-[2.5rem] p-7">
				<SectionHeading
					kicker="Topics"
					title="高频标签"
					description="标签页会自动聚合相关文章与项目条目。"
				/>
				<div class="mt-6 flex flex-wrap gap-3">
					{tags.map((item) => (
						<div class="rounded-[1.5rem] bg-white/80 px-4 py-3">
							<div class="flex items-center gap-3">
								<TagLink tag={item.tag} />
								<span class="text-sm text-[color:var(--color-ink-soft)]">{item.count} 条内容</span>
							</div>
						</div>
					))}
				</div>
			</div>

			<div class="surface-card float-panel rounded-[2.5rem] p-7">
				<SectionHeading
					kicker="Timeline"
					title="最新动态"
					description="博客和项目合并排序，用于首页动态入口与后续主页扩展。"
				/>
				<div class="mt-6 space-y-4">
					{latestUpdates.map((item) => (
						<article class="rounded-[1.5rem] bg-white/80 p-5">
							<div class="flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--color-ocean)]">
								<span>{item.type === 'post' ? 'Blog' : 'Project'}</span>
								<span>{formatDate(item.pubDate)}</span>
							</div>
							<a href={withBase(item.href)} class="mt-3 block font-display text-2xl font-bold text-[color:var(--color-ink)] hover:text-[color:var(--color-accent-strong)]">
								{item.title}
							</a>
							<p class="mt-2 text-sm leading-7 text-[color:var(--color-ink-soft)]">{item.summary}</p>
							<div class="mt-4 flex flex-wrap gap-2">
								{item.tags.map((tag) => (
									<TagLink tag={tag} />
								))}
							</div>
						</article>
					))}
				</div>
			</div>
		</section>
	</div>
</BaseLayout>
